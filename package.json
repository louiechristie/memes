{
  "name": "memes",
  "private": true,
  "version": "0.3.0",
  "author": {
    "name": "Louie Christie",
    "url": "https://www.louiechristie.com"
  },
  "scripts": {
    "start": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build && touch out/.nojekyll && node scripts/generate-sitemap.mjs --experimental-strip-types",
    "serve": "npx serve out",
    "lint": "tsc -p . && next lint",
    "deploy": "npm run build && rsync -avP ./out/ ~/Documents/louiechristie.com/_site/memes && cd ~/Documents/louiechristie.com/ && npm run deploy",
    "clean": "npx rimraf .next"
  },
  "dependencies": {
    "eslint-config-next": "15.5.11",
    "next": "15.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use-error-boundary": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3"
  }
}
